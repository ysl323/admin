# 环境配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# 生产环境 MySQL 配置（注释掉表示使用 SQLite）
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=programming_english
# DB_USER=root
# DB_PASSWORD=your_password

# Session 配置
SESSION_SECRET=your-session-secret-key-change-this-in-production

# Redis 配置（生产环境使用）
# REDIS_HOST=localhost
# REDIS_PORT=6379

# 加密密钥（用于加密 TTS API 密钥）
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-this

# 火山引擎 TTS 配置（可选，也可以在管理后台配置）
# TTS_APP_ID=your-app-id
# TTS_API_KEY=your-api-key
# TTS_API_SECRET=your-api-secret

# 日志配置
LOG_LEVEL=info

# CORS 配置
CORS_ORIGIN=http://localhost:5173
