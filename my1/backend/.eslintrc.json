{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "import/extensions": ["error", "ignorePackages"],
    "comma-dangle": ["error", "never"],
    "max-len": ["error", { "code": 120 }],
    "no-underscore-dangle": "off",
    "consistent-return": "off"
  }
}
